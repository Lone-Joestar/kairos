# =====================================================================================================
# KAIROS - Environment Variables
# Copy this file to .env and fill in your values
# =====================================================================================================

# --- Postgres ---
POSTGRES_USER=kairos
POSTGRES_PASSWORD=kairos
POSTGRES_DB=kairos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---Airflow---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://kairos:kairos@postgres:5432/kairos
AIRFLOW__CORE__FERNET_KEY=  #generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"""
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=admin
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

##--- Reddit API --
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=kairos:v1.0 (by /u/your_usernme)

# --- AWS/LocalStack ---
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=kairos-raw

# -- FastAPI ===
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

## Slack 
SLACK_WEBHOOK_URL=


